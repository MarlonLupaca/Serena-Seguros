{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Monitoreo de contenedores Docker con Telegraf - Serena Seguros",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Sección 1: Rendimiento de Procesamiento (CPU)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "unit": "percent",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (rate(docker_container_cpu_usage_total{container_name!=\"\"}[2m])) / 1e9 * 100",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Historial de Uso de CPU (%)",
      "description": "Muestra la evolución del consumo de CPU a lo largo del tiempo para cada contenedor. Útil para identificar picos de carga históricos.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (rate(docker_container_cpu_usage_total{container_name!=\"\"}[2m])) / 1e9 * 100",
          "legendFormat": "{{container_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Estado de CPU Actual (Semáforo)",
      "description": "Muestra el estado de procesamiento en tiempo real. Verde: OK (<50%), Amarillo: Advertencia (50%-80%), Rojo: Crítico (>80%).",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Sección 2: Capacidad y Consumo de Memoria (RAM)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (docker_container_mem_usage{container_name!=\"\"})",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Historial de Consumo de RAM",
      "description": "Muestra la RAM consumida en tiempo real para cada uno de los contenedores a lo largo del tiempo.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (docker_container_mem_usage{container_name!=\"\"}) / sum by (container_name) (docker_container_mem_limit{container_name!=\"\"}) * 100",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Historial del Porcentaje de Uso (%)",
      "description": "Muestra el porcentaje del límite de RAM que se ha consumido a lo largo del tiempo. Permite evaluar tendencias de crecimiento de memoria.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400000000 },
              { "color": "red", "value": 700000000 }
            ]
          },
          "unit": "bytes",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (docker_container_mem_usage{container_name!=\"\"})",
          "legendFormat": "{{container_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Cantidad de RAM Física Consumida (Bytes)",
      "description": "Muestra la cantidad exacta de memoria RAM consumida actualmente por cada contenedor en Megabytes/Gigabytes de hardware.",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 15
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (docker_container_mem_usage{container_name!=\"\"}) / sum by (container_name) (docker_container_mem_limit{container_name!=\"\"}) * 100",
          "legendFormat": "{{container_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Semáforo de Capacidad (Uso vs Límite %)",
      "description": "Evalúa el consumo frente al límite del contenedor. Verde: Seguro (<60%), Amarillo: Llenándose (60%-85%), Rojo: Al límite de saturación (>85%).",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 102,
      "title": "Sección 3: Tráfico de Red (Network I/O)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (rate(docker_container_net_rx_bytes{container_name!=\"\"}[2m]))",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Tráfico de Red Recibido (RX - Descarga)",
      "description": "Muestra la velocidad a la que cada contenedor está recibiendo datos de la red.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (rate(docker_container_net_tx_bytes{container_name!=\"\"}[2m]))",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Tráfico de Red Enviado (TX - Subida)",
      "description": "Muestra la velocidad a la que cada contenedor está transmitiendo o respondiendo datos hacia la red.",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 103,
      "title": "Sección 4: Estado Operativo y Proyección",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "Caído / Inactivo" }, "1": { "text": "En Ejecución" }, "2": { "text": "En Ejecución" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 34 },
      "id": 8,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": false,
        "text": {}
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (container_name) (docker_container_mem_usage{container_name!=\"\"}) * 0 + 1",
          "legendFormat": "{{container_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Estado de Salud en Tiempo Real (Running)",
      "description": "Estado de ejecución del contenedor. Verde (En Ejecución) significa que está levantado e interactuando. Rojo (Caído) advierte una interrupción del servicio.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "lineStyle": { "dash": [8, 4], "fill": "dash" }
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (docker_container_mem_usage{container_name!=\"\"})",
          "legendFormat": "Actual — {{container_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "predict_linear(docker_container_mem_usage{container_name!=\"\"}[30m], 3600)",
          "legendFormat": "Proyección 1h — {{container_name}}",
          "refId": "B"
        }
      ],
      "title": "Proyección del Consumo de RAM (1 Hora)",
      "description": "Compara la tendencia sólida (actual) contra la proyección lineal estimada para los siguientes 60 minutos. Previene caídas por Out Of Memory (OOM).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "lineStyle": { "dash": [8, 4], "fill": "dash" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_name) (rate(docker_container_cpu_usage_total{container_name!=\"\"}[2m])) / 1e9 * 100",
          "legendFormat": "Actual — {{container_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "predict_linear(docker_container_cpu_usage_total{container_name!=\"\"}[30m], 3600) / 1e9 * 100",
          "legendFormat": "Proyección 1h — {{container_name}}",
          "refId": "B"
        }
      ],
      "title": "Proyección del Consumo de CPU (1 Hora)",
      "description": "Proyecta la tendencia de procesamiento del CPU para la siguiente hora útil, permitiendo dimensionar el autoescalado del procesador.",
      "type": "timeseries"
    }
  ],
